# --- TrustOS environment ---
# All variables are OPTIONAL for the in-memory demo. They are required
# when migrating to the production stack described in docs/API.md.

# Postgres connection (Supabase or Railway)
DATABASE_URL="postgresql://user:password@host:5432/trustos?schema=public"

# Session cookie signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-32-bytes-of-randomness"

# Socket.io endpoint (optional — demo uses polling)
NEXT_PUBLIC_REALTIME_URL="https://realtime.trustos.app"

# Public origin (for share links and customer track URLs)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
